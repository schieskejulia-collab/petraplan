import { useState } from "react";
import { milaApi, type BusinessProfile, type AnalysisResult } from "@/api/connector";

type Mode = "rule" | "ai" | "stream";

interface UseAnalyzeReturn {
  result: AnalysisResult | null;
  streamTokens: string;
  isLoading: boolean;
  error: string | null;
  run: (profile: BusinessProfile, mode?: Mode) => Promise<AnalysisResult | null>;
  reset: () => void;
}

export function useAnalyze(): UseAnalyzeReturn {
  const [result, setResult] = useState<AnalysisResult | null>(null);
  const [streamTokens, setStreamTokens] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const reset = () => {
    setResult(null);
    setStreamTokens("");
    setError(null);
  };

  const run = async (profile: BusinessProfile, mode: Mode = "rule"): Promise<AnalysisResult | null> => {
    setIsLoading(true);
    setError(null);
    setResult(null);
    setStreamTokens("");

    try {
      if (mode === "stream") {
        const reader = await milaApi.aiAnalyzeStream(profile);
        const decoder = new TextDecoder();
        let accumulated = "";

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          const text = decoder.decode(value, { stream: true });
          const lines = text.split("\n").filter((l) => l.startsWith("data: "));
          for (const line of lines) {
            const json = JSON.parse(line.slice(6));
            if (json.done) {
              // Stream complete — parse full accumulated JSON into result
              try {
                const parsed = JSON.parse(accumulated);
                const finalResult: AnalysisResult = {
                  summary: parsed.summary ?? "",
                  insights: parsed.insights ?? [],
                  risks: parsed.risks ?? [],
                  opportunities: parsed.opportunities ?? [],
                  recommendations: parsed.recommendations ?? [],
                  automation_allowed: json.automation_allowed ?? false,
                  note: parsed.note ?? "",
                };
                setResult(finalResult);
                return finalResult;
              } catch {
                // Stream didn't produce valid JSON — return null
                return null;
              }
            } else if (json.token) {
              accumulated += json.token;
              setStreamTokens((prev) => prev + json.token);
            }
          }
        }
        return null;
      }

      const data = mode === "ai"
        ? await milaApi.aiAnalyze(profile)
        : await milaApi.analyze(profile);
      setResult(data);
      return data;
    } catch (e) {
      const msg = e instanceof Error ? e.message : "Analysis failed.";
      setError(msg);
      return null;
    } finally {
      setIsLoading(false);
    }
  };

  return { result, streamTokens, isLoading, error, run, reset };
}